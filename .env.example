# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs who have admin access
# Get your ID from @userinfobot on Telegram
ADMIN_IDS=123456789

# The Telegram group/channel chat ID where the bot operates
# Negative number for groups, e.g. -1001234567890
TARGET_GROUP_ID=-1001234567890

# ── Football Data API ─────────────────────────────────────────────────────────
# Free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_api_key_here

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically)
DB_PATH=./data/predictions.db

# Path to the admin action log directory (created automatically)
LOG_DIR=./logs
