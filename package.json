{
  "name": "football-prediction-bot",
  "version": "1.0.0",
  "description": "Telegram Football Prediction Bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/bundle.js && node -e \"require('fs').copyFileSync('node_modules/sql.js/dist/sql-wasm.wasm', 'dist/sql-wasm.wasm')\"",
    "start": "node dist/bundle.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "node-cron": "^3.0.3",
    "sql.js": "^1.12.0",
    "telegraf": "^4.15.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
